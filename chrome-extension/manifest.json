{
  "manifest_version": 3,
  "name": "NNN Axiom Search",
  "version": "1.1",
  "description": "Double-click a word on NNN Tracker to instantly search it on Axiom, with deploy buttons and enhanced modal",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/chud.jpg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:*/*", "http://127.0.0.1:*/*", "https://chud.tech/*", "https://*.chud.tech/*"],
      "js": ["tracker-content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://axiom.trade/*", "https://*.axiom.trade/*"],
      "js": ["axiom-content.js", "axiom-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://axiom.trade/*", "https://*.axiom.trade/*"]
    }
  ]
}
